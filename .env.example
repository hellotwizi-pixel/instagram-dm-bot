# Instagram Graph API
IG_PAGE_ACCESS_TOKEN=your_page_access_token_here
IG_VERIFY_TOKEN=your_verify_token_here

# Google Sheets 연동 (선택사항)
# Google Sheets ID를 설정하면 JSON 파일 대신 Google Sheets에서 키워드를 읽습니다
# 예: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
# 그 URL에서 YOUR_SHEET_ID 부분만 복사해서 입력하세요
GOOGLE_SHEETS_ID=

# Optional: For local development
NODE_ENV=development
